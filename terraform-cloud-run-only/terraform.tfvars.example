# Copier ce fichier vers terraform.tfvars et adapter les valeurs.
# Le projet, les APIs, l'interconnect, les LB et les services socle sont supposes deja livres.

project_id = "mon-projet-gcp"

region          = "us-central1"
vertex_location = "global"

name_prefix  = "gemini"
service_name = "gemini-api"

# Image construite dans Artifactory, puis lue par Cloud Run via un repository
# Artifact Registry remote.
artifactory_registry_url       = "artifactory.example.com/docker-local"
image_name                     = "gemini-api"
image_tag                      = "a-remplacer-par-le-sha"
artifact_remote_repository_id  = "artifactory-remote"
create_artifact_remote_repository = false

# Si le remote repository doit s'authentifier sur Artifactory, renseigner les
# deux valeurs ensemble. Le secret doit deja exister dans Secret Manager.
# artifactory_username                = "svc-artifactory"
# artifactory_password_secret_version = "projects/mon-projet-gcp/secrets/artifactory-password/versions/latest"

# Service account Cloud Run.
# Option 1: Terraform cree le service account et lui donne acces Vertex AI.
create_service_account = true
grant_vertex_user_role = true

# Option 2: utiliser un service account deja livre.
# create_service_account = false
# service_account_email  = "sa-cloud-run@mon-projet-gcp.iam.gserviceaccount.com"
# grant_vertex_user_role = false

# Modeles Gemini disponibilises.
gemini_default_model = "gemini-2.5-flash-lite"
gemini_models = [
  "gemini-3.5-flash",
  "gemini-2.5-flash",
  "gemini-3.1-flash",
  "gemini-2.5-flash-lite",
  "gemini-3-pro",
  "gemini-2.5-pro",
  "gemini-3.1-pro",
  "gemini-3-flash",
]

# Cloud Run reste prive par defaut; brancher ici le frontal/LB/API Gateway/APIM existant.
allow_unauthenticated = false
invoker_members = [
  # "serviceAccount:frontal-invoker@mon-projet-gcp.iam.gserviceaccount.com",
]

# Optionnel: secret applicatif si le frontal existant l'envoie via X-Internal-Api-Key.
enable_internal_api_key = false
# internal_api_key = "a-remplacer"
