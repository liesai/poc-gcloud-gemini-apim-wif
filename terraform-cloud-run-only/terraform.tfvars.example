# Copier ce fichier vers terraform.tfvars et adapter les valeurs.
# Le projet, les APIs, l'interconnect, les LB et les services socle sont supposes deja livres.

project_id = "mon-projet-gcp"

region          = "us-central1"
vertex_location = "global"

name_prefix  = "gemini"
service_name = "gemini-api"

# Image construite/poussee dans Artifact Registry par le pipeline ou deja presente:
# <region>-docker.pkg.dev/<project_id>/<artifact_registry_repository_id>/<image_name>:<image_tag>
artifact_registry_repository_id     = "gemini-repo"
create_artifact_registry_repository = false
image_name                          = "gemini-api"
image_tag                           = "a-remplacer-par-le-sha"

# Modeles Gemini disponibilises.
gemini_default_model = "gemini-2.5-flash-lite"
gemini_models = [
  "gemini-3.5-flash",
  "gemini-2.5-flash",
  "gemini-3.1-flash",
  "gemini-2.5-flash-lite",
  "gemini-3-pro",
  "gemini-2.5-pro",
  "gemini-3.1-pro",
  "gemini-3-flash",
]

# Cloud Run reste prive par defaut. Les invokers IAM et le service account
# runtime sont supposes deja geres par le socle.

# Optionnel: secret applicatif si le frontal existant l'envoie via X-Internal-Api-Key.
enable_internal_api_key = false
# internal_api_key = "a-remplacer"
