# Copier ce fichier vers terraform.tfvars et adapter les valeurs.
# Le projet, les APIs, l'interconnect, les LB et les services socle sont supposes deja livres.

project_id = "mon-projet-gcp"

region          = "us-central1"
vertex_location = "global"

name_prefix  = "gemini"
service_name = "gemini-api"

# Image construite dans Artifactory et referencee directement par Cloud Run.
artifactory_registry_url = "artifactory.example.com/docker-local"
image_name               = "gemini-api"
image_tag                = "a-remplacer-par-le-sha"

# Service account Cloud Run deja livre par le socle.
# Terraform se contente de l'associer au service Cloud Run.
service_account_email = "sa-cloud-run@mon-projet-gcp.iam.gserviceaccount.com"

# Modeles Gemini disponibilises.
gemini_default_model = "gemini-2.5-flash-lite"
gemini_models = [
  "gemini-3.5-flash",
  "gemini-2.5-flash",
  "gemini-3.1-flash",
  "gemini-2.5-flash-lite",
  "gemini-3-pro",
  "gemini-2.5-pro",
  "gemini-3.1-pro",
  "gemini-3-flash",
]

# Cloud Run reste prive par defaut; brancher ici le frontal/LB/API Gateway/APIM existant.
allow_unauthenticated = false
invoker_members = [
  # "serviceAccount:frontal-invoker@mon-projet-gcp.iam.gserviceaccount.com",
]

# Optionnel: secret applicatif si le frontal existant l'envoie via X-Internal-Api-Key.
enable_internal_api_key = false
# internal_api_key = "a-remplacer"
